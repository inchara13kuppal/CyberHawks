# GARUDATVA — backend environment configuration
# Path: backend/backend/.env
# Values match the Neo4j/Redis/Ollama setup in the deploy commands.

# ── Required (minimum) ─────────────────────────────
NEO4J_PASSWORD=garudatva
OLLAMA_BASE_URL=http://localhost:11434
AIR_GAP_MODE=false

# ── Neo4j (docker run NEO4J_AUTH=neo4j/garudatva) ──
