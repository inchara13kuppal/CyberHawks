{
    "schema_version": "1.0",
    "description": "India-specific fraud detection patterns consumed by india_patterns.py. Eight categories of regular expressions matched against extracted APK strings (DEX, manifest, assets). These are DETECTION patterns only and mirror the defensive ground of the YARA ruleset. Each pattern has an id, a regex, a weight, and a short note. Regexes are Python 're' compatible.",
    "categories": {
      "upi_payment_gateways": [
        {"id": "upi_intent", "regex": "upi://(pay|collect|mandate)", "weight": 3, "note": "UPI deep-link intent"},
        {"id": "upi_vpa", "regex": "[a-zA-Z0-9.\\-_]{2,64}@(oksbi|okhdfcbank|okicici|okaxis|ybl|ibl|axl|paytm|apl|upi|airtel|fbl)", "weight": 4, "note": "Virtual Payment Address handle"},
        {"id": "bhim_pkg", "regex": "in\\.org\\.npci\\.upiapp", "weight": 2, "note": "BHIM package reference"},
        {"id": "gpay_pkg", "regex": "com\\.google\\.android\\.apps\\.nbu\\.paisa\\.user", "weight": 1, "note": "Google Pay package reference"},
        {"id": "phonepe_pkg", "regex": "com\\.phonepe\\.app", "weight": 1, "note": "PhonePe package reference"}
      ],
      "banking_sms_sender_ids": [
        {"id": "sbi_hdr", "regex": "\\b[A-Z]{2}-SBIINB\\b", "weight": 4, "note": "SBI net-banking SMS header"},
        {"id": "icici_hdr", "regex": "\\b[A-Z]{2}-ICICIB\\b", "weight": 4, "note": "ICICI SMS header"},
        {"id": "hdfc_hdr", "regex": "\\b[A-Z]{2}-HDFCBK\\b", "weight": 4, "note": "HDFC SMS header"},
        {"id": "axis_hdr", "regex": "\\b[A-Z]{2}-AXISBK\\b", "weight": 4, "note": "Axis SMS header"},
        {"id": "kotak_hdr", "regex": "\\b[A-Z]{2}-KOTAKB\\b", "weight": 4, "note": "Kotak SMS header"},
        {"id": "generic_trai_hdr", "regex": "\\b[A-Z]{2}-[A-Z]{6}\\b", "weight": 2, "note": "Generic TRAI 6-char sender header"}
      ],
      "otp_extraction": [
        {"id": "otp_numeric", "regex": "OTP[\\s:is]{0,6}\\d{4,8}", "weight": 4, "note": "OTP followed by 4-8 digit code"},
        {"id": "otp_phrase", "regex": "(?i)one[ _]?time[ _]?password", "weight": 2, "note": "OTP phrase"},
        {"id": "do_not_share", "regex": "(?i)do not share.{0,20}(otp|code|pin)", "weight": 3, "note": "Bank OTP warning text harvested"}
      ],
      "aadhaar_patterns": [
        {"id": "aadhaar_number", "regex": "\\b[2-9]\\d{3}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b", "weight": 4, "note": "12-digit Aadhaar, leading 2-9"},
        {"id": "aadhaar_kw", "regex": "(?i)\\b(aadhaar|aadhar|uidai)\\b", "weight": 2, "note": "Aadhaar keyword"}
      ],
      "pan_patterns": [
        {"id": "pan_number", "regex": "\\b[A-Z]{5}\\d{4}[A-Z]\\b", "weight": 4, "note": "PAN format AAAAA9999A"},
        {"id": "pan_kw", "regex": "(?i)\\bpan[ _]?(card|number|no)\\b", "weight": 2, "note": "PAN keyword"}
      ],
      "fake_loan_signatures": [
        {"id": "no_cibil", "regex": "(?i)no\\s*cibil", "weight": 3, "note": "No-CIBIL marketing hook"},
        {"id": "instant_loan", "regex": "(?i)instant\\s*loan", "weight": 2, "note": "Instant-loan marketing"},
        {"id": "aadhaar_loan", "regex": "(?i)aadhaar\\s*loan", "weight": 3, "note": "Aadhaar-loan hook"},
        {"id": "no_documents", "regex": "(?i)no\\s*documents?", "weight": 2, "note": "No-documents hook"}
      ],
      "c2_infrastructure": [
        {"id": "ngrok", "regex": "(?i)ngrok(-free)?\\.(io|app)", "weight": 4, "note": "ngrok tunnel"},
        {"id": "telegram_bot", "regex": "(?i)api\\.telegram\\.org/bot", "weight": 4, "note": "Telegram bot C2/exfil"},
        {"id": "discord_webhook", "regex": "(?i)discord\\.com/api/webhooks", "weight": 4, "note": "Discord webhook exfil"},
        {"id": "onion", "regex": "[a-z2-7]{16,56}\\.onion", "weight": 4, "note": "Tor onion endpoint"},
        {"id": "ip_port", "regex": "\\b(\\d{1,3}\\.){3}\\d{1,3}:\\d{2,5}\\b", "weight": 3, "note": "Hardcoded IPv4:port"},
        {"id": "dyndns", "regex": "(?i)\\.(duckdns\\.org|no-ip\\.(org|com)|ddns\\.net|hopto\\.org)", "weight": 3, "note": "Free dynamic DNS"}
      ],
      "imps_neft_strings": [
        {"id": "imps", "regex": "(?i)\\bIMPS\\b", "weight": 1, "note": "IMPS transaction keyword"},
        {"id": "neft", "regex": "(?i)\\bNEFT\\b", "weight": 1, "note": "NEFT transaction keyword"},
        {"id": "rtgs", "regex": "(?i)\\bRTGS\\b", "weight": 1, "note": "RTGS transaction keyword"},
        {"id": "beneficiary", "regex": "(?i)add\\s*beneficiary", "weight": 2, "note": "Beneficiary-add flow abused in fraud"}
      ]
    }
  }